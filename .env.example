# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# GoDaddy API (for scripts/godaddy-dns.sh and domain:add)
# Get keys at: https://developer.godaddy.com/keys
GODADDY_API_KEY=
GODADDY_API_SECRET=

# Optional: override domain (default: opsdevco.de)
# DOMAIN=opsdevco.de

# Optional: Netlify site URL for CNAME target (auto-detected when linked)
# NETLIFY_SITE=your-site.netlify.app
