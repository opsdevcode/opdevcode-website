---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'OpsDevCo',
  description: 'Platform engineering advisory. AWS, GCP, EKS, Terraform, Karpenter, agentic development. Health checks, cost optimization, IaC cleanup.',
  url: 'https://opsdevco.de',
  email: 'eric@opsdevco.de',
  areaServed: 'Worldwide',
  serviceType: ['Platform Engineering', 'Cloud Infrastructure', 'AWS', 'GCP', 'DevOps', 'Kubernetes', 'Terraform'],
};
---

<BaseLayout
  title="OpsDevCo | Platform Engineering Advisory"
  description="OpsDevCo — platform engineering advisory. I help teams untangle AWS, GCP, EKS, trim cloud waste, make Terraform maintainable, and adopt agentic development. No corporate speak, no long contracts."
  structuredData={structuredData}
>
  <Header />
  <main id="main">
    <div class="wrap main-wrap">
      <section class="hero">
        <div class="card hero-main">
          <div class="kicker">
            <span class="pill">AWS</span>
            <span class="pill">GCP</span>
            <span class="pill">Kubernetes / EKS</span>
            <span class="pill">Terraform</span>
            <span class="pill">Agentic dev</span>
            <span class="pill">Cost + Scaling</span>
          </div>

          <h1>Your AWS, GCP, and Kubernetes setup shouldn't keep you up at night.</h1>
          <p class="sub">
            I help teams untangle AWS, GCP, EKS, trim cloud waste, make Terraform maintainable, and adopt agentic development — without hiring another full-time person.
          </p>

          <div class="tldr tldr-with-logo">
            <img src="/assets/opsdevco-logo-o-mark.png" alt="" aria-hidden="true" />
            <div><strong>In 30 seconds:</strong> Solo platform engineer. AWS, GCP, EKS, Terraform, Karpenter, agentic dev. Health checks, cost fixes, IaC cleanup. Starting at $1,200. <a href="/about#contact">Let's talk</a>.</div>
          </div>

          <div class="cta">
            <a class="btn primary" href="https://calendly.com/eric-opsdevco/30min" target="_blank" rel="noopener noreferrer">Book a call</a>
            <a class="btn" href="/about#contact">Email me</a>
            <a class="btn" href="/services">See how I work</a>
          </div>

          <p class="price-teaser">
            Engagements from <a href="/pricing">$1,200</a>. No long contracts. Async-friendly.
          </p>
          <p class="lead-magnet">
            <strong>Free:</strong> <a href="mailto:eric@opsdevco.de?subject=EKS%20health%20checklist">EKS health checklist</a> — 10 things to check before your next incident. Email with "checklist" in the subject.
          </p>
        </div>

        <aside class="card hero-side">
          <p class="side-title side-with-logo">
            <img src="/assets/opsdevco-logo-o-mark.png" alt="" aria-hidden="true" />
            <span>Sound familiar?</span>
          </p>
          <ul class="bullets">
            <li>EKS "works" but scaling feels like a gamble</li>
            <li>AWS or GCP spend keeps climbing and nobody knows why</li>
            <li>Terraform is brittle — every change feels risky</li>
            <li>You're adopting Cursor/Copilot but want to do it right</li>
            <li>Your platform team is drowning and could use a hand</li>
          </ul>
          <div style="margin-top: 14px;">
            <div class="pill">What you get: a clear roadmap and fixes that actually stick</div>
          </div>
        </aside>
      </section>

      <div class="section-divider" aria-hidden="true"></div>

      <section class="section card services-preview">
        <div class="section-header">
          <img src="/assets/opsdevco-logo-o-terminal.png" alt="" aria-hidden="true" />
          <h2 style="margin: 0;">What I do</h2>
        </div>
        <div class="grid grid-2col">
          <div class="tile">
            <h3><a href="/services#platform-health" style="color: inherit">Platform Health Check</a></h3>
            <p>I dig into your AWS, GCP, EKS, and Terraform setup and give you a straight-up report: what's working, what's not, and what to fix first.</p>
          </div>
          <div class="tile">
            <h3>Cost + Scaling</h3>
            <p>Track down what's actually driving your bill — compute waste, node strategy, autoscaling — and fix it.</p>
          </div>
          <div class="tile">
            <h3>Terraform Cleanup</h3>
            <p>Refactor so your IaC is maintainable: clearer structure, safer workflows, less "hold your breath" on every apply.</p>
          </div>
          <div class="tile">
            <h3><a href="/agentic" style="color: inherit">Agentic Development</a></h3>
            <p>Adopt AI-assisted and agentic workflows — Cursor, Copilot, custom tooling — so your team ships faster without the chaos.</p>
          </div>
        </div>
        <div style="text-align: center; margin-top: 20px;">
          <a class="btn" href="/services">View all services</a>
        </div>
      </section>

      <section class="section card testimonials">
        <div class="section-header">
          <img src="/assets/opsdevco-logo-o-terminal.png" alt="" aria-hidden="true" />
          <h2 style="margin: 0;">What clients say</h2>
        </div>
        <div class="grid" style="grid-template-columns: repeat(2, 1fr)">
          <blockquote class="tile testimonial">
            <p>"Clear, actionable report. We fixed the top three items in a week and cut our EKS bill by 40%."</p>
            <cite>— Platform lead, Series B startup</cite>
          </blockquote>
          <blockquote class="tile testimonial">
            <p>"Finally someone who gets Terraform and doesn't over-engineer. Our IaC is maintainable now."</p>
            <cite>— CTO, fintech</cite>
          </blockquote>
        </div>
      </section>

      <div style="text-align: center; margin-top: 32px; margin-bottom: 24px;">
        <a class="btn primary" href="https://calendly.com/eric-opsdevco/30min" target="_blank" rel="noopener noreferrer">Book a call</a>
        <a class="btn" href="/about#contact" style="margin-left: 10px;">Email me</a>
        <a class="btn" href="/tools" style="margin-left: 10px;">Browse tools</a>
      </div>

      <Footer />
    </div>
  </main>

  <div class="sticky-cta" aria-hidden="true">
    <a class="btn primary" href="https://calendly.com/eric-opsdevco/30min" target="_blank" rel="noopener noreferrer">Book a call</a>
  </div>
</BaseLayout>

<style>
  .kicker { color: var(--muted); display: inline-flex; gap: 10px; align-items: center; border: 1px solid var(--line); padding: 8px 12px; border-radius: 999px; background: rgba(255, 255, 255, 0.02); font-size: 14px; flex-wrap: wrap; }
  h1 { margin: 16px 0 10px; font-size: 42px; line-height: 1.12; letter-spacing: -0.6px; }
  @media (max-width: 520px) { h1 { font-size: 34px; } }
  .sub { margin: 0 0 18px; color: var(--muted); font-size: 17px; max-width: 70ch; }
  .cta { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 18px; }
  .services-preview { margin-top: 48px; }
</style>
