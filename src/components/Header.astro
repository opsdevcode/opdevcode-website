---
interface Props {
  active?: string;
}

const { active = '' } = Astro.props;
const navItems = [
  { href: '/services', label: 'Services' },
  { href: '/tools', label: 'Tools' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/about', label: 'About' },
];
---

<a href="#main" class="skip-link">Skip to main content</a>
<div class="header-wrap">
  <div class="wrap">
    <header>
      <a href="/" class="brand">
        <img src="/assets/opsdevco-logo-o-terminal.png" alt="OpsDevCo" width="24" height="24" />
        <strong>OpsDevCo</strong>
      </a>
      <nav>
        {navItems.map((item) => (
          <a href={item.href} class:list={active === item.label ? ['active'] : []}>
            {item.label}
          </a>
        ))}
        <a class="btn" href="/about#contact">Contact</a>
      </nav>
    </header>
  </div>
</div>
