---
import '../styles/site.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  structuredData?: object;
  noindex?: boolean;
}

const { title, description, canonical, structuredData, noindex = false } = Astro.props;
const canonicalUrl = canonical || new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,follow" />}
    <link rel="canonical" href={canonicalUrl} />
    <title>{title}</title>
    <link rel="icon" href="/assets/opsdevco-logo-o-terminal.png" type="image/png" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://opsdevco.de/assets/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="OpsDevCo — platform engineering advisory" />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://opsdevco.de/assets/og-image.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {structuredData && (
      <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    )}
  </head>
  <body>
    <slot />
  </body>
</html>
